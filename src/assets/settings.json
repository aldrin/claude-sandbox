{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "disableDeepLinkRegistration": "disable",
  "feedbackSurveyRate": 0,
  "prefersReducedMotion": true,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "WebSearch",
      "WebFetch(domain:index.crates.io)",
      "WebFetch(domain:static.crates.io)",
      "WebFetch(domain:192.168.64.1)",
      "Bash(cargo *)"
    ]
  },

  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [],
      "allowAllUnixSockets": false
    }
  },

  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  },

  "model": "claude-opus-4-6",

  "companyAnnouncements": [
    "Aldrin's Sandbox · verify with ~/sandbox-checks.py"
  ],

  "spinnerTipsEnabled": false,
  "voiceEnabled": false,

  "env": {
    "COLUMNS": "200",
    "LINES": "50",
    "LANG": "en_US.UTF-8",
    "COLORTERM": "truecolor",

    "TMPDIR": "/tmp/claude",
    "CARGO_TARGET_DIR": "/home/claude/cargo-target",

    "CLAUDE_CODE_TMPDIR": "/tmp/claude",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_CRON": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",

    "ENABLE_LSP_TOOL": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "FORCE_AUTOUPDATE_PLUGINS": "true",

    "DISABLE_COST_WARNINGS": "1",
    "DISABLE_INSTALLATION_CHECKS": "1"
  }
}
