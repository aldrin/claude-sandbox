# Claude Code Development Container
# Provides a complete development environment for working with Claude Code,
# including Rust toolchain and Python tools.

FROM ubuntu:26.04

ARG DEBIAN_FRONTEND=noninteractive

# Install system-level dependencies for all sections below.
#   Base:     curl, git, ca-certificates
#   Claude:   ripgrep
#   Sandbox:  bubblewrap + socat (bash isolation)
#   Rust:     build-essential, pkg-config, libssl-dev
#   Python:   python3, python3-dev
#   Docs:     fonts-ibm-plex
#   Editor:   emacs-nox
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git ca-certificates \
    ripgrep \
    bubblewrap socat \
    build-essential pkg-config libssl-dev \
    python3 python3-dev \
    fonts-ibm-plex \
    emacs-nox \
    && rm -rf /var/lib/apt/lists/*

# Pandoc (apt version lags behind; install pre-built binary from GitHub)
RUN curl -sSL https://github.com/jgm/pandoc/releases/download/3.9.0.2/pandoc-3.9.0.2-linux-arm64.tar.gz \
    | tar -xz --strip-components=1 -C /usr/local

# Typst typesetting compiler (not packaged in Ubuntu; pre-built binary from GitHub)
RUN curl -sSL https://github.com/typst/typst/releases/latest/download/typst-aarch64-unknown-linux-musl.tar.xz \
    | tar -xJ --strip-components=1 -C /usr/local/bin

# Fix bubblewrap: setuid root so it works inside the container VM
RUN chmod u+s /usr/bin/bwrap

# Create non-root user
RUN useradd -m -d /home/claude -s /bin/bash claude
USER claude

# PATH for tools installed to ~/.local/bin and ~/.cargo/bin
ENV PATH="/home/claude/.local/bin:/home/claude/.cargo/bin:${PATH}"

# Ensure 256-color support; not always inherited from the host terminal
ENV TERM=xterm-256color
ENV EDITOR=emacs

# bwrap sets TMPDIR=/tmp/claude at runtime; ensure the directory exists
RUN mkdir -p /tmp/claude

# =============================================================================
# Rust
# =============================================================================

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    --default-toolchain stable \
    --component rust-analyzer \
    --component rust-src \
    --component clippy \
    --component rustfmt \
    --component llvm-tools

# Nightly toolchain with rust-src for cargo-fuzz (libFuzzer requires nightly)
RUN rustup toolchain install nightly --component rust-src

# cargo-fuzz for running fuzz targets; cargo-llvm-cov for code coverage
RUN cargo install cargo-fuzz cargo-llvm-cov

# Shared target directory keeps build artifacts out of the project volume
ENV CARGO_TARGET_DIR="/home/claude/cargo-target"

# =============================================================================
# Python
# =============================================================================

RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Use container-local directories to avoid conflicts with host macOS packages
ENV UV_PROJECT_ENVIRONMENT="/home/claude/.venv"
ENV UV_CACHE_DIR="/home/claude/.cache/uv"

RUN uv tool install basedpyright \
    && ln -s basedpyright-langserver /home/claude/.local/bin/pyright-langserver

# =============================================================================
# DuckDB
# =============================================================================

RUN curl https://install.duckdb.org | sh

# =============================================================================
# Claude Code (last among installs — changes most often, protects layer cache)
# =============================================================================

RUN curl -fsSL https://claude.ai/install.sh | bash

# Pre-install plugins so they are available from the first session without prompting
RUN claude plugin marketplace add anthropics/claude-plugins-official \
    && claude plugin install rust-analyzer-lsp@claude-plugins-official \
    && claude plugin install pyright-lsp@claude-plugins-official \
    && claude plugin install code-simplifier@claude-plugins-official \
    && claude plugin install feature-dev@claude-plugins-official

# =============================================================================
# Workspace — root-owned config files (Edit/Write tools bypass bwrap)
# =============================================================================

# Switch to root so COPY produces root-owned files that the claude user
# cannot modify in place (Edit/Write tools bypass bwrap restrictions)
USER root

COPY claude.json /home/claude/.claude.json
RUN mkdir -p /home/claude/.claude
COPY settings.json /home/claude/.claude/settings.json
COPY CLAUDE.md /home/claude/CLAUDE.md
COPY .gitconfig /home/claude/.gitconfig
COPY sandbox-checks.py /home/claude/sandbox-checks.py
COPY sandbox-tools.py /home/claude/sandbox-tools.py

USER claude
WORKDIR /home/claude
ENTRYPOINT ["claude"]
