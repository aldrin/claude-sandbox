{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "mcp__aws__aws___read_documentation",
      "mcp__aws__aws___search_documentation",
      "WebSearch",
      "WebFetch(domain:index.crates.io)",
      "WebFetch(domain:static.crates.io)",
      "WebFetch(domain:192.168.64.1)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "hooks": {
    "SessionStart": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "UserPromptSubmit": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }]
      }
    ],
    "PostToolUse": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "PostToolUseFailure": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "Stop": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "SubagentStart": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "SubagentStop": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }],
    "SessionEnd": [{ "hooks": [{ "type": "http", "url": "__HOOKS_ENDPOINT__", "timeout": 5 }] }]
  },
  "spinnerTipsEnabled": false,
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "DISABLE_AUTOUPDATER": "1",
    "FORCE_AUTOUPDATE_PLUGINS": "true",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_COST_WARNINGS": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_TMPDIR": "/home/claude/tmp",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_METRICS_INCLUDE_VERSION": "true"
  }
}
