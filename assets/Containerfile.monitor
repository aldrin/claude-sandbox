# Claude Monitor Container
# Lightweight OTLP receiver that captures Claude Code telemetry into Parquet.
# Runs as a long-lived container, shared across Claude sessions.

FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates build-essential pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -d /home/claude -s /bin/bash claude
USER claude
RUN mkdir -p /home/claude/.local/bin
ENV PATH="/home/claude/.local/bin:${PATH}"

# Install Rust (minimal profile — only needed to build claude-monitor)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    --default-toolchain stable --profile minimal
ENV PATH="/home/claude/.cargo/bin:${PATH}"

RUN cargo install --git https://github.com/aldrin/claude-monitor.git \
    && cp /home/claude/.cargo/bin/claude-monitor /home/claude/.local/bin/claude-monitor \
    && rustup self uninstall -y \
    && rm -rf /home/claude/.cargo

RUN mkdir -p /home/claude/telemetry

EXPOSE 4318

ENTRYPOINT ["claude-monitor", "run", "--data-dir", "/home/claude/telemetry"]
